<?php

// $_GET, $_Post = special variable used to collect data from an HTML form
//                 data is sent to file in the action attribute of <form>
//                 <form action="some_file.php" method="get">

// $_GET = Data is append to the url 
//         NOT SECURE
//         char limit
//         Bookmark is possible to w/ values
//         GET request can be cached
//         Better for a search page

// $_POST = Data is packaged inside the body of http request
//          MORE SECURE
//          No data limit
//          Cannot bookmark
//          GET request are not cached
//          Better for submitting credentials